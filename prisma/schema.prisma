generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum PhotoStatus {
  available
  sold
  hidden
}

enum PurchaseStatus {
  pending
  paid
  refunded
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  plan                   Plan      @default(FREE)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  photographer  Photographer?
  purchases     Purchase[]
  imageSearches ImageSearch[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Photographer {
  id             String    @id @default(cuid())
  userId         String    @unique
  displayName    String
  pixKey         String?
  commissionRate Float     @default(0.8)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos    Photo[]
  galleries Gallery[]
}

model Gallery {
  id             String    @id @default(cuid())
  photographerId String
  eventId        String?
  routeName      String
  date           DateTime
  photoCount     Int       @default(0)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  photographer Photographer @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  photos       Photo[]
}

model Photo {
  id             String      @id @default(cuid())
  urlWatermarked String
  urlFullres     String
  lat            Float?
  lng            Float?
  takenAt        DateTime
  eventId        String?
  photographerId String
  galleryId      String?
  priceBrl       Float
  status         PhotoStatus @default(available)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  photographer Photographer @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  gallery      Gallery?     @relation(fields: [galleryId], references: [id])
  purchases    Purchase[]
}

model Purchase {
  id          String         @id @default(cuid())
  userId      String
  photoId     String
  amountBrl   Float
  pixTxid     String?
  status      PurchaseStatus @default(pending)
  purchasedAt DateTime       @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id])
}

model ImageSearch {
  id              String    @id @default(cuid())
  userId          String
  embeddingVector Bytes?
  createdAt       DateTime  @default(now())
  consentGivenAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
